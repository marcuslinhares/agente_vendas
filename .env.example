# Database
DB_PASSWORD=localdev

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# Evolution API
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=your-key-here
EVOLUTION_WEBHOOK_SECRET=your-webhook-secret

# OpenAI
OPENAI_API_KEY=sk-...

# LLM config
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM Provider (openai or openrouter)
LLM_PROVIDER=openrouter

# OpenRouter (optional - for cheaper models)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat

# JWT (CRM, used in P2)
JWT_SECRET=change-me-in-production

# CORS Settings
CORS_ORIGINS=https://your-production-domain.com,http://localhost:3000
